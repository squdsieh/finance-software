# Server
NODE_ENV=development
PORT=3000
API_VERSION=v1
CORS_ORIGINS=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cloudbooks_pro
DB_USER=cloudbooks
DB_PASSWORD=cloudbooks_dev_password
DB_POOL_MIN=2
DB_POOL_MAX=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption
ENCRYPTION_KEY=your-256-bit-encryption-key-change-me

# S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=cloudbooks_minio
S3_SECRET_KEY=cloudbooks_minio_password
S3_BUCKET=cloudbooks-uploads
S3_REGION=us-east-1

# Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
EMAIL_FROM=noreply@cloudbooks.pro

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Plaid
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox

# Exchange Rates
EXCHANGE_RATES_API_KEY=your_open_exchange_rates_key

# OCR
GOOGLE_CLOUD_VISION_KEY=your_google_cloud_vision_key

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# App
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
